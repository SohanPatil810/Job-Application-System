# Root ignore settings for the Job Portal project

# Java build output
backend/target/
backend/**/*.class

# Sensitive backend config
backend/src/main/resources/application.properties
backend/src/main/resources/application.yml
backend/.mvn/
backend/logs/
backend/uploads/

# Keep example files in source control, but not real secrets
!backend/src/main/resources/application.properties.example
!frontend/.env.example

# Node/Vite build output
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Sensitive frontend config
frontend/.env
frontend/.env.*

# IDE/editor
.vscode/
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sw?

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
